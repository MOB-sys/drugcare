# ==============================================================================
# 약먹어 (YakMeogeo) Ops — crontab 설정 예시
# ==============================================================================
# ⚠️ Watchdog 데몬 사용 시 아래 cron은 불필요합니다.
#    Watchdog가 health-check, QA, daily-report, DB backup을 모두 관리합니다.
#    Watchdog 시작: scripts/maintenance/watchdog/watchdog-daemon.sh start
#
# Watchdog 미사용 시에만 아래 cron을 등록하세요:
# ==============================================================================

SHELL=/bin/bash
API_BASE_URL=http://localhost:8000
LOG_DIR=/var/log/yakmeogeo
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# --- [레거시] 헬스체크: 30분마다 (Watchdog 사용 시 불필요) ---
# */30 * * * * API_BASE_URL=$API_BASE_URL LOG_DIR=$LOG_DIR ALERT_WEBHOOK_URL=$ALERT_WEBHOOK_URL /opt/yakmeogeo/scripts/ops/health-check.sh >> /var/log/yakmeogeo/cron.log 2>&1

# --- [레거시] QA 모니터: 6시간마다 (Watchdog 사용 시 불필요) ---
# 0 */6 * * * API_BASE_URL=$API_BASE_URL LOG_DIR=$LOG_DIR ALERT_WEBHOOK_URL=$ALERT_WEBHOOK_URL /opt/yakmeogeo/scripts/ops/qa-monitor.sh >> /var/log/yakmeogeo/cron.log 2>&1

# --- [레거시] 일일 보고서: 매일 09:00 (Watchdog 사용 시 불필요) ---
# 0 9 * * * API_BASE_URL=$API_BASE_URL LOG_DIR=$LOG_DIR ALERT_WEBHOOK_URL=$ALERT_WEBHOOK_URL /opt/yakmeogeo/scripts/ops/daily-report.sh >> /var/log/yakmeogeo/cron.log 2>&1

# --- Watchdog 자체 감시: 5분마다 데몬 생존 확인 (권장) ---
*/5 * * * * /opt/yakmeogeo/scripts/maintenance/watchdog/watchdog-daemon.sh status > /dev/null 2>&1 || /opt/yakmeogeo/scripts/maintenance/watchdog/watchdog-daemon.sh start >> /var/log/yakmeogeo/cron.log 2>&1

# --- 로그 로테이션: 매주 일요일 03:00 ---
0 3 * * 0 find /var/log/yakmeogeo -name "*.log" -mtime +30 -delete 2>/dev/null
0 3 * * 0 find $HOME/.pillright-mt/logs -name "*.log" -mtime +30 -delete 2>/dev/null
0 3 * * 0 find $HOME/.pillright-mt/backups -name "*.sql.gz" -mtime +14 -delete 2>/dev/null
